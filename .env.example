# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=ley_privacidad_cl
ANONYMIZED_TELEMETRY=False
CHROMA_TELEMETRY=false

# LangSmith (opcional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_key_here
LANGCHAIN_PROJECT=cl-dataguard

# Corpus legal: directorio con los 3 archivos .md (prioridad: 21.719 > mixta > 19.628)
#   ley_21719.md, ley_mixta_sucia.md, ley_19628.md
LEGAL_CORPUS_DIR=./data/leyes_base

# Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=100
TOP_K_RESULTS=3

# Evaluación RAG (opcional)
# RAG_EVAL_CORPUS_DIR=./data/leyes_base
# RAG_EVAL_CHROMA_ROOT=./outputs/rag_eval/.chroma_scratch
# RAG_EVAL_SEED=
